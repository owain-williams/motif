{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node"],
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "isolatedModules": false,
    "resolveJsonModule": true
  },
  "include": ["bin", "lib", "scripts"],
  "exclude": ["node_modules", "cdk.out"]
}
