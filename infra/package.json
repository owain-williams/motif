{
  "name": "@motif/infra",
  "version": "0.0.0",
  "private": true,
  "description": "AWS CDK infrastructure for Motif's serverless backend (Cognito + DynamoDB + S3 + HTTP API)",
  "scripts": {
    "synth": "cdk synth",
    "diff": "cdk diff",
    "deploy": "cdk deploy --require-approval never",
    "destroy": "cdk destroy --force",
    "typecheck": "tsc --noEmit",
    "test": "node --test lambda/*.test.js",
    "smoke": "ts-node scripts/smoke-auth.ts"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.600.0",
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "aws-cdk-lib": "^2.155.0",
    "constructs": "^10.3.0"
  },
  "devDependencies": {
    "@aws-sdk/client-cloudformation": "^3.600.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.600.0",
    "@types/node": "^20.14.0",
    "aws-cdk": "^2.155.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  }
}
