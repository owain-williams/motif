{
  "expo": {
    "name": "Motif Capture",
    "slug": "motif-capture",
    "version": "0.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.motif.capture",
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "Motif syncs your ideas to Bridge on your computer over your local network."
      }
    },
    "android": {
      "package": "com.motif.capture",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-audio",
      "expo-sharing"
    ]
  }
}
