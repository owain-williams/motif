{
  "expo": {
    "name": "Motif Capture",
    "slug": "motif-capture",
    "version": "0.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.motif.capture",
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "Motif discovers Bridge and syncs your ideas over your local network.",
        "NSBonjourServices": [
          "_motif-bridge._tcp"
        ]
      }
    },
    "android": {
      "package": "com.motif.capture",
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.ACCESS_WIFI_STATE",
        "android.permission.CHANGE_WIFI_MULTICAST_STATE"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-audio",
      "expo-sharing",
      "@siteed/audio-studio",
      "expo-background-task",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Motif tags your recordings with where you made them when you turn on location tagging."
        }
      ]
    ]
  }
}
